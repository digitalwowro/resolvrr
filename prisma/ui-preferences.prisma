model UiPreference {
  id                   String              @id @default(cuid())
  userId               String
  helpdeskConnectionId String?
  key                  String
  valueJson            Json
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  helpdeskConnection   HelpdeskConnection? @relation(fields: [helpdeskConnectionId], references: [id], onDelete: Cascade)

  @@unique([userId, helpdeskConnectionId, key])
  @@index([userId])
}
