model WorkspaceAiPrompt {
  id                   String             @id @default(cuid())
  helpdeskConnectionId String
  promptKey            String
  encryptedPrompt      String
  keyVersion           String             @default("v1")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  helpdeskConnection   HelpdeskConnection @relation(fields: [helpdeskConnectionId], references: [id], onDelete: Cascade)

  @@unique([helpdeskConnectionId, promptKey])
  @@index([helpdeskConnectionId])
}

model WorkspaceAiRephraseStyle {
  id                   String             @id @default(cuid())
  helpdeskConnectionId String
  label                String
  seedKey              String?
  encryptedPrompt      String?
  keyVersion           String             @default("v1")
  sortOrder            Int
  isEnabled            Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  helpdeskConnection   HelpdeskConnection @relation(fields: [helpdeskConnectionId], references: [id], onDelete: Cascade)
  userOverrides        UserAiRephraseStyleOverride[]

  @@unique([helpdeskConnectionId, seedKey])
  @@index([helpdeskConnectionId, sortOrder])
}

model UserAiRephraseStyleOverride {
  id                   String                    @id @default(cuid())
  userId               String
  helpdeskConnectionId String
  styleId              String
  encryptedPrompt      String
  keyVersion           String             @default("v1")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  helpdeskConnection   HelpdeskConnection @relation(fields: [helpdeskConnectionId], references: [id], onDelete: Cascade)
  style                WorkspaceAiRephraseStyle @relation(fields: [styleId], references: [id], onDelete: Cascade)

  @@unique([userId, helpdeskConnectionId, styleId])
  @@index([helpdeskConnectionId])
}
