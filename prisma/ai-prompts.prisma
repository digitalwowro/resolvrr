model WorkspaceAiPrompt {
  id                   String             @id @default(cuid())
  workspaceId          String
  promptKey            String
  encryptedPrompt      String
  keyVersion           String             @default("v1")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  workspace            Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, promptKey])
  @@index([workspaceId])
}

model WorkspaceAiRephraseStyle {
  id                   String             @id @default(cuid())
  workspaceId          String
  label                String
  seedKey              String?
  encryptedPrompt      String?
  keyVersion           String             @default("v1")
  sortOrder            Int
  isEnabled            Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  workspace            Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userOverrides        UserAiRephraseStyleOverride[]

  @@unique([workspaceId, seedKey])
  @@index([workspaceId, sortOrder])
}

model UserAiRephraseStyleOverride {
  id                   String                    @id @default(cuid())
  userId               String
  workspaceId          String
  styleId              String
  encryptedPrompt      String
  keyVersion           String             @default("v1")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace            Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  style                WorkspaceAiRephraseStyle @relation(fields: [styleId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId, styleId])
  @@index([workspaceId])
}
