model TaskbarSyncState {
  id                   String                   @id @default(cuid())
  helpdeskConnectionId String                   @unique
  identityVersion      String
  compatibility        TaskbarSyncCompatibility @default(UNKNOWN)
  contractVersion      String?
  initializedAt        DateTime?
  lastSynchronizedAt   DateTime?
  lastErrorCode        String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  helpdeskConnection   HelpdeskConnection       @relation(fields: [helpdeskConnectionId], references: [id], onDelete: Cascade)
  operations           TaskbarSyncOperation[]
}

model TaskbarSyncOperation {
  id                 String                   @id @default(cuid())
  taskbarSyncStateId String
  dedupeKey          String
  kind               TaskbarSyncOperationKind
  payloadJson        Json
  actionAt           DateTime                 @default(now())
  attemptCount       Int                      @default(0)
  nextAttemptAt      DateTime                 @default(now())
  lastErrorCode      String?
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  taskbarSyncState   TaskbarSyncState         @relation(fields: [taskbarSyncStateId], references: [id], onDelete: Cascade)

  @@unique([taskbarSyncStateId, dedupeKey])
  @@index([taskbarSyncStateId, nextAttemptAt])
}
