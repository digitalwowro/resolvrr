model Workspace {
  id                       String                        @id @default(cuid())
  ownerUserId              String
  providerKey              String
  displayName              String
  baseUrl                  String
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @updatedAt
  signatureSource          WorkspaceSignatureSource      @default(NONE)
  signatureVersion         String                        @default(cuid())
  owner                    User                          @relation("WorkspaceOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  memberships              WorkspaceMembership[]
  helpdeskConnections      HelpdeskConnection[]
  savedViews               SavedView[]
  workspaceAiSetting       WorkspaceAiSetting?
  userAiSettings           UserWorkspaceAiSetting[]
  workspaceAiPrompts       WorkspaceAiPrompt[]
  aiRephraseStyles         WorkspaceAiRephraseStyle[]
  aiRephraseStyleOverrides UserAiRephraseStyleOverride[]
  myStyles                 WorkspaceMyStyle[]
  uiPreferences            UiPreference[]
  providerMutationLogs     ProviderMutationLog[]
  signatureTemplates       WorkspaceSignatureTemplate[]

  @@index([ownerUserId])
  @@index([providerKey])
}

model HelpdeskConnection {
  id                          String                   @id @default(cuid())
  workspaceId                 String
  userId                      String
  status                      HelpdeskConnectionStatus @default(DISCONNECTED)
  providerIdentityExternalId  String?
  providerIdentityDisplayName String?
  identityVersion             String                   @default(cuid())
  createdAt                   DateTime                 @default(now())
  updatedAt                   DateTime                 @updatedAt
  workspace                   Workspace                @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user                        User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  credentials                 ProviderCredential[]
  ticketSnapshotCaches        TicketSnapshotCache[]
  threadSnapshotCaches        ThreadSnapshotCache[]
  aiSummaryCaches             AiSummaryCache[]
  providerMutationLogs        ProviderMutationLog[]
  taskbarSyncState            TaskbarSyncState?

  @@unique([workspaceId, userId])
  @@unique([workspaceId, providerIdentityExternalId])
  @@index([userId])
  @@index([workspaceId])
}

model WorkspaceMembership {
  id                              String                  @id @default(cuid())
  userId                          String
  workspaceId                     String
  role                            WorkspaceMembershipRole @default(AGENT)
  canEditMyStyle                  Boolean                 @default(false)
  canEditAiRephraseStyleOverrides Boolean                 @default(false)
  createdAt                       DateTime                @default(now())
  updatedAt                       DateTime                @updatedAt
  user                            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace                       Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model ProviderCredential {
  id                   String             @id @default(cuid())
  helpdeskConnectionId String
  scheme               String
  encryptedPayload     String
  keyVersion           String             @default("v1")
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  helpdeskConnection   HelpdeskConnection @relation(fields: [helpdeskConnectionId], references: [id], onDelete: Cascade)

  @@unique([helpdeskConnectionId, scheme])
}

model ProviderMutationLog {
  id                   String              @id @default(cuid())
  userId               String
  workspaceId          String
  helpdeskConnectionId String?
  providerKey          String
  providerTicketId     String?
  capability           String
  status               String
  errorKind            String?
  durationMs           Int?
  createdAt            DateTime            @default(now())
  user                 User                @relation(fields: [userId], references: [id], onDelete: Restrict)
  workspace            Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Restrict)
  helpdeskConnection   HelpdeskConnection? @relation(fields: [helpdeskConnectionId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([workspaceId, createdAt])
  @@index([helpdeskConnectionId, createdAt])
}
