generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum HelpdeskConnectionStatus {
  ACTIVE
  DISCONNECTED
  AUTH_FAILED
}

enum SavedViewVisibility {
  PERSONAL
  SHARED
}

enum TicketState {
  NEW
  OPEN
  PENDING_REMINDER
  PENDING_CLOSE
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
}

enum WorkspaceAiPolicy {
  DISABLED
  ADMIN_MANAGED
  USER_PROVIDED
}

enum AiProviderProtocol {
  OPENAI_COMPATIBLE
  ANTHROPIC_COMPATIBLE
}

enum WorkspaceMembershipRole {
  ADMIN
  AGENT
}

enum WorkspaceSignatureSource {
  NONE
  ZAMMAD
  RESOLVRR
}

enum TaskbarSyncCompatibility {
  UNKNOWN
  SUPPORTED
  UNSUPPORTED
}

enum TaskbarSyncOperationKind {
  OPEN
  CLOSE
  ACTIVATE
  DEACTIVATE
  REORDER
}
