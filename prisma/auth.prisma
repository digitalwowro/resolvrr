model User {
  id                   String                    @id @default(cuid())
  email                String                    @unique
  displayName          String?
  firstName            String?
  lastName             String?
  avatarDataUrl        String?
  role                 UserRole                  @default(USER)
  deactivatedAt        DateTime?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt
  passwordLogin        PasswordLogin?
  sessions             Session[]
  helpdeskConnections  HelpdeskConnection[]
  workspaceMemberships WorkspaceMembership[]
  savedViews           SavedView[]
  savedViewPreferences UserSavedViewPreference[]
  ticketSnapshotCaches TicketSnapshotCache[]
  threadSnapshotCaches ThreadSnapshotCache[]
  aiSummaryCaches      AiSummaryCache[]
  userAiSettings       UserWorkspaceAiSetting[]
  myStyles             WorkspaceMyStyle[]
  aiRephraseStyleOverrides UserAiRephraseStyleOverride[]
  uiPreferences        UiPreference[]
  providerMutationLogs ProviderMutationLog[]
}

model PasswordLogin {
  userId       String   @id
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id               String   @id @default(cuid())
  userId           String
  sessionTokenHash String   @unique
  expiresAt        DateTime
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
